# Copy to terraform.tfvars and fill in. This box is DELIBERATELY separate from your mainnet-wallet
# node and runs keyless (-disablewallet) so it can never hold funds.

ssh_public_key    = "ssh-ed25519 AAAA... you@host"
tailscale_authkey = "tskey-auth-..."

# The Docker image that contains your patched qbitd/qbit-cli build (same one the lab uses).
# Leave empty to install Docker only and start qbitd by hand.
qbitd_image     = "your-registry/qbitbuild:latest"
qbitd_bin       = "/src/build/bin/qbitd"
qbitd_chain_arg = "-testnet4"          # -regtest | -testnet4 | "" for mainnet

rpc_user     = "lab"
rpc_password = "change-me"
rpc_port     = 18332

# disablewallet = true                 # keyless by default; set false only if you truly need a wallet
