+// Enumerate every pubkey occupying a CHECKSIGPQC / CHECKSIGADD position in an arbitrary P2MR
+// leaf. Unlike ParseP2MRScript() -- which only recognises the pk()/multi_a templates the node
+// can *finalise* -- this enumerates keys in leaves the node cannot finalise (e.g. HTLCs), so a
+// held key can still contribute a partial script-path signature for PSBT handoff to a downstream
+// finaliser or co-signer. Mirrors Bitcoin Core emitting partial tapscript signatures for scripts
+// it does not finalise itself.
+static void ExtractP2MRSignableKeys(std::span<const unsigned char> script_bytes, std::vector<CPQCPubKey>& pubkeys)
+{
+    pubkeys.clear();
+    const CScript script(script_bytes.begin(), script_bytes.end());
+    CScript::const_iterator it{script.begin()};
+    opcodetype opcode;
+    std::vector<unsigned char> push_data;
+    std::vector<unsigned char> last_push;
+    bool have_last_push{false};
+    while (it != script.end()) {
+        if (!script.GetOp(it, opcode, push_data)) {
+            pubkeys.clear(); // malformed: contribute nothing rather than guess
+            return;
+        }
+        if ((opcode == OP_CHECKSIGPQC || opcode == OP_CHECKSIGADD) && have_last_push &&
+            last_push.size() == CPQCPubKey::SIZE) {
+            CPQCPubKey key{std::span<const unsigned char>(last_push)};
+            if (key.IsValid()) AddUniqueP2MRPubKey(pubkeys, key);
+        }
+        if (opcode <= OP_PUSHDATA4 && !push_data.empty()) {
+            last_push = push_data;
+            have_last_push = true;
+        } else {
+            have_last_push = false;
+        }
+    }
+}
